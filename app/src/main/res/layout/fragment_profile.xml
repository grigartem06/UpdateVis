<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".ProfileFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 👤 Заголовок профиля -->
            <TextView
                android:id="@+id/textView6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Профиль пользователя"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:layout_marginBottom="20dp"
                android:background="#FFFFFF"
                android:elevation="2dp" />

            <!-- 📋 Карточка данных пользователя -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp">

                <!-- 🔵 Закруглённая цветная область с фото профиля -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="#1565C0"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <androidx.cardview.widget.CardView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="60dp"
                            app:cardElevation="4dp"
                            app:cardUseCompatPadding="true">

                            <ImageView
                                android:id="@+id/imageView4"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                tools:src="@drawable/user" />

                        </androidx.cardview.widget.CardView>

                    </FrameLayout>

                </androidx.cardview.widget.CardView>

                <!-- Имя -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Имя"
                    android:textSize="13sp"
                    android:textColor="#546E7A"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editTextTextName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="textPersonName"
                    android:text=""
                    android:hint="Имя"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#9E9E9E"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@android:drawable/edit_text"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:layout_marginBottom="16dp" />

                <!-- Телефон -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Телефон"
                    android:textSize="13sp"
                    android:textColor="#546E7A"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editTextTextPhone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="phone"
                    android:text=""
                    android:hint="Номер телефона"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#9E9E9E"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@android:drawable/edit_text"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:layout_marginBottom="16dp" />

                <!-- Роль -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Роль"
                    android:textSize="13sp"
                    android:textColor="#546E7A"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editTextTextRole"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="text"
                    android:text=""
                    android:hint="Роль"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#9E9E9E"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@android:drawable/edit_text"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:layout_marginBottom="16dp" />

                <!-- Информация -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Информация"
                    android:textSize="13sp"
                    android:textColor="#546E7A"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editTextTextInf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:text="информация о вас"
                    android:hint="Информация"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#9E9E9E"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:background="@android:drawable/edit_text"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:minLines="2"
                    android:gravity="top|start" />

            </LinearLayout>

            <!-- 🔘 Кнопки управления -->
            <Button
                android:id="@+id/buttonEdit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Изменить"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#07A6F3"
                android:layout_marginTop="20dp"
                android:elevation="4dp" />

            <Button
                android:id="@+id/buttonLogOut"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Выйти"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:backgroundTint="#FFEBEE"
                android:layout_marginTop="10dp"
                android:elevation="2dp" />

            <!-- 📋 Список пользователей (для админов) -->
            <TextView
                android:id="@+id/textView7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Список всех пользователей:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:fontFamily="sans-serif-medium"
                android:paddingVertical="12dp"
                android:paddingStart="4dp"
                android:layout_marginTop="24dp"
                android:background="#FFFFFF"
                android:elevation="2dp" />

            <!-- 📊 RecyclerView пользователей -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewUsers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="#FFFFFF"
                android:padding="8dp"
                android:clipToPadding="false"
                android:scrollbars="vertical"
                android:scrollbarStyle="outsideOverlay"
                android:fadeScrollbars="true"
                android:elevation="2dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>