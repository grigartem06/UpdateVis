<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".OrdersFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 📌 Заголовок раздела -->
        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ваши заказы"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:fontFamily="sans-serif-medium"
            android:paddingVertical="10dp"
            android:paddingStart="4dp"
            android:letterSpacing="0.02"
            android:layout_marginBottom="12dp"
            android:background="#FFFFFF"
            android:elevation="2dp" />

        <!-- 📋 Список заказов -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/ListOfOrders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:clipToPadding="false"
            android:scrollbars="vertical"
            android:scrollbarStyle="outsideOverlay"
            android:fadeScrollbars="true"
            android:elevation="2dp"
            android:overScrollMode="ifContentScrolls" />

        <!-- 📭 Индикатор пустого списка (опционально, скрыт по умолчанию) -->
        <TextView
            android:id="@+id/emptyOrdersMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="У вас пока нет заказов"
            android:textSize="15sp"
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:padding="32dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</FrameLayout>