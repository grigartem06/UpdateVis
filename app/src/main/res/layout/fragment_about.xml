<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".AboutFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- 🖼️ Изображение с оформлением -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp">

            <!-- Декоративный фон за изображением -->
            <View
                android:layout_width="320dp"
                android:layout_height="327dp"
                android:background="#E3F2FD"
                android:layout_gravity="center" />

            <!-- Основное изображение -->
            <ImageView
                android:id="@+id/imageView"
                android:layout_width="308dp"
                android:layout_height="315dp"
                android:src="@drawable/img"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:elevation="4dp"
                android:contentDescription="@string/app_name" />

            <!-- Акцентная рамка (опционально) -->
            <View
                android:layout_width="308dp"
                android:layout_height="315dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:elevation="6dp" />
        </FrameLayout>

        <!-- 📝 Текстовый блок -->
        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/aboytUPK"
            android:textSize="16sp"
            android:textColor="#1A1A1A"
            android:lineSpacingExtra="4sp"
            android:gravity="center"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:fontFamily="sans-serif" />

        <!-- Декоративный разделитель (опционально) -->
        <View
            android:layout_width="64dp"
            android:layout_height="4dp"
            android:background="#07A6F3"
            android:layout_gravity="center"
            android:layout_marginTop="20dp" />

        <!-- Дополнительная информация (опционально, можно заполнить) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UPK BTPI"
            android:textSize="13sp"
            android:textColor="#546E7A"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.1"
            android:textAllCaps="true" />

    </LinearLayout>
</FrameLayout>