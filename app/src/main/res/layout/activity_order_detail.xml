<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".order_detail_Activity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textView9"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Информация о заказе"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/textViewId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="id"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/textViewExecutorId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="executorId"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/textViewCustomerId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="customerId"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/textViewDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="date"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/textViewStatusName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="statusName"
            android:textSize="16sp"/>

        <Spinner
            android:id="@+id/spinnerStatusName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5sp"
            android:minHeight="48dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/textViewCustomersComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="customersComment"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/editTextCustomersComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:inputType="text"
            android:minHeight="48dp"
            android:text="Name"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/textViewUserComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="userComment"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/editTextUserComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:inputType="text"
            android:minHeight="48dp"
            android:text="Name"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/textViewProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="productName"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/editButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5sp"
            android:text="edit"
            android:visibility="gone"/>

        <Button
            android:id="@+id/ButtonSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5sp"
            android:text="save"
            android:visibility="gone"/>

        <Button
            android:id="@+id/buttonDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5sp"
            android:text="Удалить"
            android:visibility="gone"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/backBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5sp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#1E88E5"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:text="назад"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>