<resources>
    <!-- 💎 Значение информации (карточка) -->
    <style name="InfoValue">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/info_card_bg</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">#1A1A1A</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="InfoCard" parent="InfoValue" />

    <!-- ✏️ Поле ввода -->
    <style name="StyledInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/input_field_bg</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">#1A1A1A</item>
        <item name="android:textColorHint">#9E9E9E</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="InputField" parent="StyledInput" />

    <!-- 🔽 Выпадающий список -->
    <style name="StyledSpinner">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/input_field_bg</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">#1A1A1A</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:popupBackground">@drawable/popup_bg</item>
    </style>

    <style name="InputSpinner" parent="StyledSpinner" />

    <!-- 🔵 Основная кнопка -->
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:backgroundTint">#07A6F3</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">4dp</item>
        <item name="rippleColor">#40FFFFFF</item>
    </style>

    <!-- 🔘 Вторичная кнопка -->
    <style name="SecondaryButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:backgroundTint">#78909C</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- 🟢 Кнопка сохранения -->
    <style name="SuccessButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:backgroundTint">#4CAF50</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- 🔴 Кнопка удаления/опасности -->
    <style name="DangerButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:backgroundTint">#D32F2F</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- ⚪ Контурная кнопка -->
    <style name="OutlineButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textColor">#546E7A</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">#B0BEC5</item>
        <item name="strokeWidth">1.5dp</item>
    </style>

    <!-- ☑️ Чекбокс -->
    <style name="StyledCheckBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#1A1A1A</item>
    </style>

    <!-- 🖼️ Скругление для фото -->
    <style name="RoundedImage">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- 💎 Значение информации (крупное, для названия) -->
    <style name="InfoValue.Large" parent="InfoValue">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#07A6F3</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

</resources>